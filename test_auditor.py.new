#!/usr/bin/env python3
"""
Test Auditor - Quality Testing Suite
Tests for auto_research_loop.py, dashboard.py, evaluate_10_dimensions.py
"""

import pytest
import json
import tempfile
import os
import sys
from pathlib import Path
from unittest.mock import patch, MagicMock
from io import StringIO
import importlib.util

# Import directly from local files using importlib
def load_local_module(module_name, file_path):
    spec = importlib.util.spec_from_file_location(module_name, file_path)
    module = importlib.util.module_from_spec(spec)
    sys.modules[module_name] = module
    spec.loader.exec_module(module)
    return module

# Load local modules
auto_research_loop = load_local_module("auto_research_loop", "/workspace/claude_audit/auto_research_loop.py")
dashboard = load_local_module("dashboard", "/workspace/claude_audit/dashboard.py")
evaluate_10_dimensions = load_local_module("evaluate_10_dimensions", "/workspace/claude_audit/evaluate_10_dimensions.py")

# Import classes
from auto_research_loop import (
    ToolBasedEvaluator, LLMBasedAnalyzer, DashboardIntegrator, AutoResearchLoop
)
from dashboard import (
    QualityDataStore, TechnicalDebtTracker, HotspotMap, 
    EvolutionReport, QualityDashboard
)
from evaluate_10_dimensions import (
    ToolBasedChecker, LLMAnalyzer, run_10_dimension_evaluation
)


