class TestToolBasedEvaluator:
    """Test ToolBasedEvaluator class"""
    
    def test_init_with_valid_repo_path(self):
        """Test initialization with valid repo path"""
        evaluator = ToolBasedEvaluator("/tmp")
        assert evaluator.repo_path == Path("/tmp")
    
    def test_init_with_dot_path(self):
        """Test initialization with current directory"""
        evaluator = ToolBasedEvaluator(".")
        assert evaluator.repo_path == Path(".")
    
    def test_run_constitution_check_returns_dict(self):
        """Test constitution check returns valid dict"""
        evaluator = ToolBasedEvaluator("/tmp")
        result = evaluator.run_constitution_check()
        assert isinstance(result, dict)
        assert "score" in result
    
    def test_run_constitution_check_with_fallback(self):
        """Test constitution check fallback when module unavailable"""
        evaluator = ToolBasedEvaluator("/tmp")
        evaluator.constitution = None
        result = evaluator.run_constitution_check()
        assert result["score"] == 50
        assert "error" in result
    
    def test_run_quality_gate_returns_dict(self):
        """Test quality gate returns valid dict"""
        evaluator = ToolBasedEvaluator("/tmp")
        result = evaluator.run_quality_gate()
        assert isinstance(result, dict)
        assert "overall" in result
    
    def test_evaluate_all_tools_returns_combined_results(self):
        """Test evaluate_all_tools returns tool_overall"""
        evaluator = ToolBasedEvaluator("/tmp")
        with patch("sys.stdout", new=StringIO()):
            result = evaluator.evaluate_all_tools()
        assert "tool_overall" in result
        assert "constitution" in result
        assert "quality_gate" in result


class TestLLMBasedAnalyzer:
    """Test LLMBasedAnalyzer class"""
    
    def test_init_with_default_model(self):
        """Test initialization with default model"""
        analyzer = LLMBasedAnalyzer()
        assert analyzer.model == "claude"
    
    def test_init_with_custom_model(self):
        """Test initialization with custom model"""
        analyzer = LLMBasedAnalyzer(model="gpt")
        assert analyzer.model == "gpt"
    
    def test_prioritize_dimensions_with_valid_data(self):
        """Test prioritize_dimensions with valid tool results"""
        analyzer = LLMBasedAnalyzer()
        tool_results = {
            "quality_gate": {
                "dimensions": {
                    "test_coverage": 30,
                    "type_safety": 80,
                    "error_handling": 50
                }
            }
        }
        result = analyzer.prioritize_dimensions(tool_results)
        assert isinstance(result, list)
        assert len(result) > 0
        assert result[0] == "test_coverage"
    
    def test_prioritize_dimensions_with_empty_data(self):
        """Test prioritize_dimensions with empty tool results"""
        analyzer = LLMBasedAnalyzer()
        result = analyzer.prioritize_dimensions({})
        assert isinstance(result, list)
        assert len(result) > 0
    
    def test_prioritize_dimensions_with_missing_dimensions(self):
        """Test prioritize_dimensions with missing dimensions key"""
        analyzer = LLMBasedAnalyzer()
        result = analyzer.prioritize_dimensions({"quality_gate": {}})
        assert isinstance(result, list)
        assert len(result) > 0
    
    def test_analyze_root_cause_known_dimension(self):
        """Test analyze_root_cause with known dimension"""
        analyzer = LLMBasedAnalyzer()
        result = analyzer.analyze_root_cause("test_coverage", {})
        assert isinstance(result, str)
        assert "測試" in result or "test" in result.lower()
    
    def test_analyze_root_cause_unknown_dimension(self):
        """Test analyze_root_cause with unknown dimension"""
        analyzer = LLMBasedAnalyzer()
        result = analyzer.analyze_root_cause("unknown_dimension", {})
        assert isinstance(result, str)
    
    def test_generate_improvements_known_dimension(self):
        """Test generate_improvements with known dimension"""
        analyzer = LLMBasedAnalyzer()
        result = analyzer.generate_improvements("test_coverage")
        assert isinstance(result, list)
        assert len(result) > 0
    
    def test_generate_improvements_unknown_dimension(self):
        """Test generate_improvements with unknown dimension"""
        analyzer = LLMBasedAnalyzer()
        result = analyzer.generate_improvements("unknown")
        assert isinstance(result, list)
        assert len(result) > 0
    
    def test_make_decision_keep_higher(self):
        """Test make_decision when score improved"""
        analyzer = LLMBasedAnalyzer()
        result = analyzer.make_decision(50, 70)
        assert result == "KEEP"
    
    def test_make_decision_revert_lower(self):
        """Test make_decision when score decreased"""
        analyzer = LLMBasedAnalyzer()
        result = analyzer.make_decision(70, 50)
        assert result == "REVERT"
    
    def test_make_decision_keep_equal(self):
        """Test make_decision when score equal"""
        analyzer = LLMBasedAnalyzer()
        result = analyzer.make_decision(50, 50)
        assert result == "KEEP"


class TestDashboardIntegrator:
    """Test DashboardIntegrator class"""
    
    def test_init_with_custom_data_file(self):
        """Test initialization with custom data file"""
        integrator = DashboardIntegrator("custom_data.json")
        assert integrator.data_file == "custom_data.json"
    
    def test_init_with_default_data_file(self):
        """Test initialization with default data file"""
        integrator = DashboardIntegrator()
        assert integrator.data_file == "quality_data.json"
    
    def test_update_debt_trend(self):
        """Test update_debt_trend"""
        with tempfile.TemporaryDirectory() as tmpdir:
            data_file = os.path.join(tmpdir, "test_data.json")
            integrator = DashboardIntegrator(data_file)
            integrator.update_debt_trend(1, 75.0)
            assert Path(data_file).exists()
    
    def test_update_hotspots(self):
        """Test update_hotspots"""
        with tempfile.TemporaryDirectory() as tmpdir:
            data_file = os.path.join(tmpdir, "test_data.json")
            integrator = DashboardIntegrator(data_file)
            module_data = {"module1": {"issues": 5, "complexity": 3, "debt": 2}}
            integrator.update_hotspots(module_data)
            assert Path(data_file).exists()
    
    def test_add_evolution(self):
        """Test add_evolution"""
        with tempfile.TemporaryDirectory() as tmpdir:
            data_file = os.path.join(tmpdir, "test_data.json")
            integrator = DashboardIntegrator(data_file)
            integrator.add_evolution(1, "before", "after", "Test", "description")
            assert Path(data_file).exists()
    
    def test_update_json_creates_file(self):
        """Test _update_json creates file if not exists"""
        with tempfile.TemporaryDirectory() as tmpdir:
            data_file = os.path.join(tmpdir, "new_data.json")
            integrator = DashboardIntegrator(data_file)
            integrator._update_json("iterations", {"test": "data"})
            assert Path(data_file).exists()


