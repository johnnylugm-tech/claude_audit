class TestToolBasedChecker:
    """Test ToolBasedChecker class"""
    
    def test_init(self):
        """Test initialization"""
        checker = ToolBasedChecker("/tmp")
        assert checker.repo_path == Path("/tmp")
    
    def test_init_with_dot(self):
        """Test initialization with current directory"""
        checker = ToolBasedChecker(".")
        assert checker.repo_path == Path(".")
    
    def test_check_type_safety_empty_repo(self):
        """Test check_type_safety with empty repo"""
        with tempfile.TemporaryDirectory() as tmpdir:
            checker = ToolBasedChecker(tmpdir)
            result = checker.check_type_safety()
            assert result == 0
    
    def test_check_type_safety_with_files(self):
        """Test check_type_safety with Python files"""
        with tempfile.TemporaryDirectory() as tmpdir:
            test_file = os.path.join(tmpdir, "test.py")
            with open(test_file, 'w') as f:
                f.write("def foo(x: int) -> str:\n    return str(x)\n")
            checker = ToolBasedChecker(tmpdir)
            result = checker.check_type_safety()
            assert result >= 0
    
    def test_check_test_coverage_empty(self):
        """Test check_test_coverage with no test files"""
        with tempfile.TemporaryDirectory() as tmpdir:
            checker = ToolBasedChecker(tmpdir)
            result = checker.check_test_coverage()
            assert result == 0
    
    def test_check_test_coverage_with_tests(self):
        """Test check_test_coverage with test files"""
        with tempfile.TemporaryDirectory() as tmpdir:
            test_file = os.path.join(tmpdir, "test_example.py")
            with open(test_file, 'w') as f:
                f.write("def test_one():\n    assert True\ndef test_two():\n    assert True\n")
            checker = ToolBasedChecker(tmpdir)
            result = checker.check_test_coverage()
            assert result > 0
    
    def test_check_security_no_issues(self):
        """Test check_security with no security issues"""
        with tempfile.TemporaryDirectory() as tmpdir:
            test_file = os.path.join(tmpdir, "safe.py")
            with open(test_file, 'w') as f:
                f.write("def hello():\n    print('hello')\n")
            checker = ToolBasedChecker(tmpdir)
            result = checker.check_security()
            assert result == 100
    
    def test_check_security_with_eval(self):
        """Test check_security with eval usage"""
        with tempfile.TemporaryDirectory() as tmpdir:
            test_file = os.path.join(tmpdir, "unsafe.py")
            with open(test_file, 'w') as f:
                f.write("eval('1+1')\n")
            checker = ToolBasedChecker(tmpdir)
            result = checker.check_security()
            assert result < 100
    
    def test_check_architecture_empty(self):
        """Test check_architecture with no files"""
        with tempfile.TemporaryDirectory() as tmpdir:
            checker = ToolBasedChecker(tmpdir)
            result = checker.check_architecture()
            assert result == 0
    
    def test_check_architecture_small_files(self):
        """Test check_architecture with small files"""
        with tempfile.TemporaryDirectory() as tmpdir:
            test_file = os.path.join(tmpdir, "small.py")
            with open(test_file, 'w') as f:
                f.write("x = 1\n")
            checker = ToolBasedChecker(tmpdir)
            result = checker.check_architecture()
            assert result > 0
    
    def test_check_readability_no_long_functions(self):
        """Test check_readability with short functions"""
        with tempfile.TemporaryDirectory() as tmpdir:
            test_file = os.path.join(tmpdir, "clean.py")
            with open(test_file, 'w') as f:
                f.write("def foo():\n    return 1\n")
            checker = ToolBasedChecker(tmpdir)
            result = checker.check_readability()
            assert result == 100
    
    def test_check_error_handling_no_handling(self):
        """Test check_error_handling with no error handling"""
        with tempfile.TemporaryDirectory() as tmpdir:
            test_file = os.path.join(tmpdir, "no_error.py")
            with open(test_file, 'w') as f:
                f.write("def foo():\n    return 1\n")
            checker = ToolBasedChecker(tmpdir)
            result = checker.check_error_handling()
            assert result == 0
    
    def test_check_error_handling_with_handling(self):
        """Test check_error_handling with error handling"""
        with tempfile.TemporaryDirectory() as tmpdir:
            test_file = os.path.join(tmpdir, "has_error.py")
            with open(test_file, 'w') as f:
                f.write("try:\n    x = 1\nexcept:\n    pass\n")
            checker = ToolBasedChecker(tmpdir)
            result = checker.check_error_handling()
            assert result > 0
    
    def test_check_documentation_no_docs(self):
        """Test check_documentation with no docs"""
        with tempfile.TemporaryDirectory() as tmpdir:
            test_file = os.path.join(tmpdir, "no_doc.py")
            with open(test_file, 'w') as f:
                f.write("x = 1\n")
            checker = ToolBasedChecker(tmpdir)
            result = checker.check_documentation()
            assert result == 0
    
    def test_check_documentation_with_docs(self):
        """Test check_documentation with docs"""
        with tempfile.TemporaryDirectory() as tmpdir:
            test_file = os.path.join(tmpdir, "has_doc.py")
            with open(test_file, 'w') as f:
                f.write('"""Module docstring"""\ndef foo():\n    """Function docstring"""\n    pass\n')
            checker = ToolBasedChecker(tmpdir)
            result = checker.check_documentation()
            assert result > 0
    
    def test_check_claims_no_claims(self):
        """Test check_claims with no claims"""
        with tempfile.TemporaryDirectory() as tmpdir:
            checker = ToolBasedChecker(tmpdir)
            result = checker.check_claims()
            assert result >= 0
    
    def test_check_claims_with_todos(self):
        """Test check_claims with TODO comments"""
        with tempfile.TemporaryDirectory() as tmpdir:
            test_file = os.path.join(tmpdir, "todo.py")
            with open(test_file, 'w') as f:
                f.write("# TODO: Fix this\n# FIXME: Do that\n")
            checker = ToolBasedChecker(tmpdir)
            result = checker.check_claims()
            assert result > 0


class TestLLMAnalyzer:
    """Test LLMAnalyzer class"""
    
    def test_init(self):
        """Test initialization"""
        analyzer = LLMAnalyzer()
        assert analyzer is not None
    
    def test_analyze_dimension_known(self):
        """Test analyze_dimension with known dimension"""
        analyzer = LLMAnalyzer()
        result = analyzer.analyze_dimension("Linting", 40)
        assert isinstance(result, dict)
        assert "description" in result
        assert "suggestion" in result
        assert "priority" in result
    
    def test_analyze_dimension_unknown(self):
        """Test analyze_dimension with unknown dimension"""
        analyzer = LLMAnalyzer()
        result = analyzer.analyze_dimension("UnknownDim", 40)
        assert isinstance(result, dict)
        assert "priority" in result
    
    def test_analyze_dimension_low_score_high_priority(self):
        """Test analyze_dimension assigns HIGH priority for low scores"""
        analyzer = LLMAnalyzer()
        result = analyzer.analyze_dimension("Linting", 40)
        assert result["priority"] == "HIGH"
    
    def test_analyze_dimension_medium_score_medium_priority(self):
        """Test analyze_dimension assigns MEDIUM priority for medium scores"""
        analyzer = LLMAnalyzer()
        result = analyzer.analyze_dimension("Linting", 60)
        assert result["priority"] == "MEDIUM"
    
    def test_analyze_dimension_high_score_low_priority(self):
        """Test analyze_dimension assigns LOW priority for high scores"""
        analyzer = LLMAnalyzer()
        result = analyzer.analyze_dimension("Linting", 80)
        assert result["priority"] == "LOW"


class TestRun10DimensionEvaluation:
    """Test run_10_dimension_evaluation function"""
    
